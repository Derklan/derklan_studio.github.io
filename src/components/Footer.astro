      <div class="brand">
        <!-- MODIFIER : Logo -->
        <span class="logo-mark"></span>
        <!-- MODIFIER : Nom du studio -->
        <b>STUDIO</b>
      </div>
      <!-- MODIFIER : Description -->
      <p class="blurb">Studio de jeux indépendant. On crée des mondes qu'on n'a pas envie de quitter.</p>
    </div>
    <div class="footer-cols">
      <div class="footer-col">
        <h5>// STUDIO</h5>
        <a href="/jeux">Jeux</a>
        <a href="/studio">Le studio</a>
        <a href="/fondateurs">Fondateurs</a>
        <a href="/actualites">Devlog</a>
      </div>
      <div class="footer-col">
        <h5>// SUIVRE</h5>
        <!-- MODIFIER : Liens réseaux -->
        <a href="#">Steam</a>
        <a href="#">itch.io</a>
        <a href="#">Discord</a>
        <a href="#">X</a>
        <a href="#">YouTube</a>
      </div>
      <div class="footer-col">
