---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Fondateurs — STUDIO" page="fondateurs">
<style>
  .founders-hero{position:relative;min-height:100svh;display:flex;align-items:center;justify-content:center;text-align:center;padding:140px 24px 80px;overflow:hidden}
  .founders-hero .hero-bg{position:absolute;inset:0;z-index:0;background:radial-gradient(70% 60% at 30% 30%,rgba(255,46,126,.22),transparent 55%),radial-gradient(70% 60% at 70% 70%,rgba(177,75,255,.22),transparent 55%),linear-gradient(180deg,#0c0a12,#0a0a0c)}
  .founders-hero .inner{position:relative;z-index:2;max-width:700px}
  .founders-hero h1{font-family:var(--display);font-weight:700;font-size:clamp(42px,8vw,90px);letter-spacing:-.04em;line-height:.94;text-transform:uppercase}
  .founders-hero .sub{margin:26px auto 0;max-width:38ch;color:#c2c2cb;font-size:clamp(17px,2.2vw,21px)}
  .duo{display:grid;grid-template-columns:1fr 1fr;gap:40px;max-width:var(--maxw);margin:0 auto}
  @media(max-width:820px){.duo{grid-template-columns:1fr;gap:60px;max-width:520px}}
  .portrait{display:flex;flex-direction:column;align-items:center}
  .portrait-frame{width:100%;aspect-ratio:3/4;border-radius:20px;border:1px solid var(--line);transition:border-color .5s,box-shadow .5s}
  .portrait-frame:hover{border-color:rgba(177,75,255,.5);box-shadow:0 30px 80px -30px var(--glow)}
  .pf1{background:radial-gradient(120% 100% at 30% 10%,rgba(255,46,126,.30),transparent 55%),linear-gradient(170deg,#1a1228,#0a0a0c)}
  .pf2{background:radial-gradient(120% 100% at 70% 10%,rgba(177,75,255,.30),transparent 55%),linear-gradient(170deg,#1a1228,#0a0a0c)}
  .portrait-info{text-align:center;margin-top:28px}
  .portrait-info h3{font-family:var(--display);font-size:clamp(28px,4vw,38px);font-weight:700}
  .portrait-info .handle{font-family:var(--mono);font-size:14px;color:var(--g2);margin-top:6px}
  .portrait-info .role{font-family:var(--mono);font-size:12px;color:var(--muted);margin-top:8px;text-transform:uppercase}
  .portrait-info .bio{color:#b0b0b8;font-size:16px;line-height:1.65;margin-top:18px;max-width:38ch;margin-inline:auto}
  .divider{height:2px;max-width:200px;margin:0 auto;background:var(--grad);border-radius:2px}
  .quote-section{text-align:center;padding:clamp(80px,14vw,180px) 24px}
  .quote{font-family:var(--display);font-size:clamp(26px,4.5vw,48px);font-weight:600;letter-spacing:-.02em;line-height:1.15;max-width:20ch;margin:0 auto;font-style:italic;color:#e4e4ea}
  .quote::before{content:"«";color:var(--g2);font-style:normal}
  .quote::after{content:"»";color:var(--g2);font-style:normal}
  .quote-attr{font-family:var(--mono);font-size:13px;color:var(--muted);margin-top:22px}
  .socials{display:flex;gap:16px;justify-content:center;margin-top:18px}
  .socials a{font-family:var(--mono);font-size:12px;color:var(--muted);border:1px solid var(--line);border-radius:8px;padding:6px 14px;transition:color .25s,border-color .25s}
  .socials a:hover{color:var(--g2);border-color:rgba(177,75,255,.5)}
</style>
  <header class="founders-hero"><div class="hero-bg"></div><div class="inner">
    <p class="eyebrow">// founders()</p><h1>Les deux <span class="grad-text">cerveaux</span>.</h1>
    <p class="sub">Deux amis, une vision, zéro compromis.</p></div></header>
  <section class="section" style="padding-top:0"><div class="duo">
    <div class="portrait reveal"><div class="portrait-frame pf1"></div><div class="portrait-info"><h3>Prénom Nom</h3><p class="handle">@pseudo</p><p class="role">Co-founder · CEO</p><p class="bio">Bio courte.</p><div class="socials"><a href="#">LinkedIn</a><a href="#">X</a><a href="#">GitHub</a></div></div></div>
    <div class="portrait reveal"><div class="portrait-frame pf2"></div><div class="portrait-info"><h3>Prénom Nom</h3><p class="handle">@pseudo</p><p class="role">Co-founder · CEO</p><p class="bio">Bio courte.</p><div class="socials"><a href="#">LinkedIn</a><a href="#">X</a><a href="#">GitHub</a></div></div></div>
  </div></section>
  <div class="divider reveal"></div>
  <section class="quote-section"><p class="quote reveal">On a pas commencé pour devenir un studio. On a commencé parce qu'on pouvait pas s'en empêcher.</p><p class="quote-attr reveal">— Les fondateurs</p></section>
  <section class="mono-block" style="padding-top:0"><h2 class="reveal">Envie de<br/><span class="grad-text">bosser</span><br/>avec nous ?</h2><p class="reveal">On cherche des gens qui partagent la même obsession.</p><div style="margin-top:36px" class="reveal"><a class="btn-primary" href="/contact">NOUS CONTACTER</a></div></section>
</Layout>
