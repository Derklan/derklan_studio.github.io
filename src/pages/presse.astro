---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Presse — STUDIO" page="presse">
  <header class="page-hero"><div class="glow"></div><p class="eyebrow">// press.kit()</p>
    <h1>Tout ce qu'il <span class="grad-text">vous faut</span>.</h1>
    <p class="sub">Logos, captures, descriptions et faits. Servez-vous.</p></header>
  <section class="section" style="padding-top:20px"><div class="wrap">
    <div class="head reveal"><p class="label">// identity</p><h2>Fiche d'identité</h2></div>
    <div class="fact-grid reveal">
      <div class="fact"><p class="k">Studio</p><p class="v">STUDIO</p></div>
      <div class="fact"><p class="k">Fondé en</p><p class="v">2024</p></div>
      <div class="fact"><p class="k">Basé à</p><p class="v">France</p></div>
      <div class="fact"><p class="k">Taille</p><p class="v">Équipe indépendante</p></div>
      <div class="fact"><p class="k">Plateformes</p><p class="v">PC · Quest</p></div>
      <div class="fact"><p class="k">Contact presse</p><p class="v">press@studio.com</p></div>
    </div></div></section>
  <section class="section" style="padding-top:0"><div class="wrap">
    <div class="head reveal"><p class="label">// assets.download()</p><h2>Ressources</h2></div>
    <div class="asset-grid">
      <div class="asset reveal"><div class="ph"></div><div class="row"><span>Logo</span><a href="#">Télécharger</a></div></div>
      <div class="asset reveal"><div class="ph"></div><div class="row"><span>Captures</span><a href="#">Télécharger</a></div></div>
      <div class="asset reveal"><div class="ph"></div><div class="row"><span>Key art</span><a href="#">Télécharger</a></div></div>
    </div>
    <div style="text-align:center;margin-top:40px" class="reveal"><a class="btn-primary" href="#">TÉLÉCHARGER LE KIT COMPLET</a></div>
  </div></section>
</Layout>
