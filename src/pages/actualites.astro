---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Devlog — STUDIO" page="actualites">
  <header class="page-hero"><div class="glow"></div><p class="eyebrow">// console.log()</p>
    <h1>Les <span class="grad-text">coulisses</span>.</h1>
    <p class="sub">Mises à jour, notes de production et coups de gueule occasionnels.</p></header>
  <section class="section" style="padding-top:20px"><div class="wrap">
    <div class="post-list" id="devlog-posts"><p style="text-align:center;color:var(--muted);font-family:var(--mono);padding:60px 0">// chargement...</p></div>
    <div style="text-align:center;margin-top:48px"><a class="btn-link" href="/admin" style="font-size:12px;color:var(--muted)">// admin</a></div>
  </div></section>
  <script src="/admin.js"></script>
</Layout>
